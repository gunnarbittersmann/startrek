						"@type": "TVEpisode",
						"inLanguage": "de",
						"name": "Kids von heute",
						"datePublished": "2026-01-15"
					},
					"subjectOf": {
						"@type": "Webpage",
						"inLanguage": "en",
						"publisher": {
							"@type": "Organization",
							"@id": "https://bittersmann.de/startrek/organizations#Wikipedia",
