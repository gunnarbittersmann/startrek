				{
					"@type": "TVEpisode",
					"@id": "https://bittersmann.de/startrek/series/sfa#1.9",
					"episodeNumber": "1.9",
					"name": "300th Night",
					"datePublished": "2026-03-05",
					"duration": "PT56M",
					"workTranslation": {
						"@type": "TVEpisode",
						"inLanguage": "de",
						"name": "Die 300. Nacht",
						"datePublished": "2026-03-05"
					},
					"director": {
						"@type": "Person",
						"@id": "https://bittersmann.de/startrek/people#JonathanFrakes",
						"name": "Jonathan Frakes"
					},
					"author": {
						"@type": "Person",
						"@id": "https://bittersmann.de/startrek/people#KirstenBeyer",
						"name": "Kirsten Beyer"
					},
					"contributor": [
						{
							"@type": "Person",
							"@id": "https://bittersmann.de/startrek/people#KirstenBeyer",
							"name": "Kirsten Beyer"
						},
						{
							"@type": "Person",
							"@id": "https://bittersmann.de/startrek/people#KennethLin",
							"name": "Kenneth Lin"
						}
					],
					"description": [
						{
							"@language": "en",
							"@value": "At the end of the academic year, the cadets perform a ritual declaring themselves as a chosen family. At the same time, Starfleet pulls back after it’s discovered that Braka has weaponized the apocalyptic Omega molecule. Finally receiving a message from Anisha, Caleb, Darem, SAM and Genesis go after her on a planet in Venari Ral space, followed by Ake, Reno, the Doctor and a stowaway Jay-Den and Tarima; the rest of the cadets and crew are left behind on Betazed. Caleb considers abandoning Starfleet for his mother, but goes back when his friends are in trouble. The group is rescued by the Athena and they discover that Braka has boxed the Federation in with Omega mines, leaving only the Athena on the outside. As Reno broadcasts a distress call to all Federation ships, Ake is reunited with a frightened Anisha."
						}
					],
