					"workTranslation": {
						"@type": "TVEpisode",
						"inLanguage": "de",
						"name": "Vitus Reflux",
						"datePublished": "2026-01-22"
					},
					"subjectOf": {
						"@type": "Webpage",
						"inLanguage": "en",
						"publisher": {
							"@type": "Organization",
							"@id": "https://bittersmann.de/startrek/organizations#Wikipedia",
