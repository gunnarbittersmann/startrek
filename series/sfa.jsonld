				{
					"@type": "TVEpisode",
					"@id": "https://bittersmann.de/startrek/series/sfa#1.5",
					"episodeNumber": "1.5",
					"name": "Series Acclimation Mil",
					"datePublished": "2026-02-05",
					"duration": "PT58M",
					"workTranslation": {
						"@type": "TVEpisode",
						"inLanguage": "de",
						"name": "Series Acclimation Mil",
						"datePublished": "2026-02-05"
					},
					"subjectOf": {
						"@type": "Webpage",
						"inLanguage": "en",
						"publisher": {
							"@type": "Organization",
							"@id": "https://bittersmann.de/startrek/organizations#Wikipedia",
